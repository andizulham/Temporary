# =========================================================
#  CONTOH FILE KONFIGURASI  --  salin menjadi ".env"
#  Jangan pernah commit file .env asli ke GitHub!
# =========================================================

# --- Gemini API (otak AI Agent) ---
# Dapatkan gratis di: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=masukkan_api_key_gemini_disini
GEMINI_MODEL=gemini-2.5-flash

# --- Helius (data on-chain Solana) ---
# Dapatkan gratis di: https://dashboard.helius.dev
HELIUS_API_KEY=masukkan_api_key_helius_disini

# --- Telegram Bot (antarmuka) ---
# Buat bot lewat @BotFather di Telegram
TELEGRAM_BOT_TOKEN=masukkan_token_bot_telegram_disini

# --- Dompet Solana yang ingin dipantau ---
# Alamat publik (bukan private key!) dompet trading kamu
WALLET_ADDRESS=masukkan_alamat_dompet_solana_disini

# --- Pengaturan tambahan ---
# Mata uang tampilan estimasi (kurs USD->IDR), ubah sesuai kurs terbaru
USD_TO_IDR=16300
