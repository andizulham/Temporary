# =========================================================
#  CONTOH FILE KONFIGURASI  --  salin menjadi ".env"
#  Jangan pernah commit file .env asli ke GitHub!
#  (cukup isi yang kamu pakai; sisanya boleh dibiarkan)
# =========================================================

# --- Gemini API (otak AI autonomous) ---
# Dapatkan GRATIS di: https://aistudio.google.com/app/apikey
# Jika dikosongkan, bot tetap jalan memakai mode "tanpa AI" (rule-based) untuk testing.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Pilih gateway WhatsApp: "fonnte" | "meta" | "console" ---
# fonnte  = gateway lokal Indonesia (paling mudah & murah)
# meta    = WhatsApp Cloud API resmi dari Meta
# console = tidak kirim ke mana-mana, hanya cetak ke layar (untuk testing)
WHATSAPP_PROVIDER=console

# --- Opsi A: Fonnte (gateway WhatsApp lokal Indonesia) ---
# Dapatkan token di dashboard Fonnte setelah menyambungkan device.
FONNTE_TOKEN=

# --- Opsi B: Meta WhatsApp Cloud API (resmi) ---
META_WA_TOKEN=
META_WA_PHONE_NUMBER_ID=
# Token verifikasi webhook (bebas kamu tentukan, samakan di dashboard Meta)
META_VERIFY_TOKEN=rahasia123

# --- Identitas bisnis (dipakai di sapaan & jawaban) ---
BUSINESS_NAME=Toko Maju Jaya
BUSINESS_HOURS=Senin-Jumat 09.00-18.00 WIB
TIMEZONE_OFFSET=7

# --- Lokasi database lead (boleh dibiarkan default) ---
DB_PATH=leads.db
